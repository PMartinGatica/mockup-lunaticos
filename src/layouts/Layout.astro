---
import Header from '@/components/Header.astro'
import Footer from '@/components/Footer.astro'
import '@fontsource/oswald/400.css'
import '@fontsource/oswald/600.css'
import '@fontsource/oswald/700.css'
import '@fontsource/dm-sans/400.css'
import '@fontsource/dm-sans/500.css'
import '@fontsource/dm-sans/600.css'

interface Props {
  title?: string
  description?: string
}

const {
  title = 'Lunáticos Indumentaria — Ushuaia',
  description = 'Indumentaria deportiva y artículos de regalería en Ushuaia. Camisetas oficiales, buzos y más. Lunes a Sábados de 10 a 13 y de 15:30 a 20 hs.',
} = Astro.props
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <Header />
    <slot />
    <Footer />

    <!-- ── Floating WhatsApp button ── -->
    <a
      href="https://api.whatsapp.com/send?phone=5492901505599&text=Hola%20Lun%C3%A1ticos!%20Quisiera%20consultar%20por..."
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Consultar por WhatsApp"
      class="wa-fab fixed bottom-5 right-5 z-[90] flex items-center gap-2.5
             bg-[#25D366] text-white font-dm font-700 text-sm
             pl-4 pr-5 py-3.5 rounded-full
             shadow-[0_4px_20px_rgba(37,211,102,0.45)]
             hover:shadow-[0_4px_30px_rgba(37,211,102,0.7)]
             hover:scale-105 active:scale-95
             transition-all duration-200"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" class="shrink-0"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      <span>WhatsApp</span>
    </a>

    <style is:global>
      :root {
        color-scheme: dark;
        --color-bg: #000000;
        --color-surface: #111111;
        --color-surface-2: #1A1A1A;
        --color-primary: #00C040;
        --color-primary-light: #33DD66;
        --color-danger: #CC0000;
        --entry-animation: -20px;
      }

      @media (min-width: 1400px) {
        :root { --entry-animation: -80px; }
      }

      html {
        font-family: 'DM Sans', system-ui, sans-serif;
        background: var(--color-bg);
        scroll-behavior: smooth;
      }

      body { overflow-x: hidden; }

      /* Scrollbar */
      ::-webkit-scrollbar { width: 6px; }
      ::-webkit-scrollbar-track { background: transparent; }
      ::-webkit-scrollbar-thumb {
        background: rgba(34, 197, 94, 0.3);
        border-radius: 4px;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: rgba(34, 197, 94, 0.6);
      }

      p {
        color: rgba(255,255,255,0.65);
        line-height: 1.65;
        font-size: 1rem;
        font-weight: 400;
      }

      /* Glow hover utility */
      .text__glow {
        transition: color 0.25s ease, text-shadow 0.25s ease;
      }
      .text__glow:hover {
        color: var(--color-primary);
        text-shadow: 0 0 16px rgba(34, 197, 94, 0.5);
      }

      /* Header scroll blur — CSS scroll timeline (igual esland) */
      #header-nav {
        animation: nav-blur linear both;
        animation-timeline: scroll();
        animation-range: 0 350px;
      }
      @keyframes nav-blur {
        to {
          background: rgba(10, 10, 10, 0.85);
          backdrop-filter: blur(14px);
          box-shadow: 0 2px 30px rgba(0,0,0,0.5),
                      0 1px 0 rgba(34, 197, 94, 0.08);
        }
      }

      /* Glow button */
      .btn-glow {
        transition: box-shadow 0.3s ease, background-color 0.2s ease;
      }
      .btn-glow:hover {
        box-shadow: 0 0 24px rgba(34, 197, 94, 0.45), 0 0 48px rgba(34, 197, 94, 0.15);
      }

      /* Section title */
      .section-title {
        font-family: 'Oswald', sans-serif;
        font-weight: 700;
        letter-spacing: 0.02em;
        text-transform: uppercase;
        color: white;
        line-height: 1.05;
      }

      /* Accent tag */
      .tag {
        font-family: 'DM Sans', sans-serif;
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        color: var(--color-primary);
      }
    </style>
  </body>
</html>
