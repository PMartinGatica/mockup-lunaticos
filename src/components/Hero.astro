---
const WA = 'https://api.whatsapp.com/send?phone=5492901505599&text=Hola%20Lun%C3%A1ticos!%20Quisiera%20consultar%20sobre...'
---

<!--
  ─── HERO: GTA VI–style scroll cinematic ───
  #hero-wrapper   → 300vh scroll space (sticky anchor)
  #hero-sticky    → stays fixed in viewport while scrolling through 300vh
  #hero-scene     → zooms out on scroll (scale 1.12 → 1)
  #hero-content   → logo + tagline + CTAs (fades up on scroll)
  #hero-footer    → info chips (fades on scroll)
  #logo-mask      → brand "L" grow-reveal (appears as content fades, then fades out)
-->

<div id="hero-wrapper" class="relative" style="height: 300vh;" id="inicio">
  <div id="hero-sticky" class="sticky top-0 overflow-hidden" style="height: 100dvh;">

    <!-- ─── Layer 1: Background scene ─── -->
    <div id="hero-scene" class="absolute inset-0 bg-black">

      <!-- Halftone corners matching logo -->
      <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
        <div class="absolute top-0 left-0 w-56 h-56 md:w-80 md:h-80 halftone-red opacity-55"></div>
        <div class="absolute top-0 right-0 w-56 h-56 md:w-80 md:h-80 halftone-green opacity-55"></div>
        <div class="absolute bottom-0 left-0 w-36 h-36 md:w-56 md:h-56 halftone-green opacity-25"></div>
        <div class="absolute bottom-0 right-0 w-36 h-36 md:w-56 md:h-56 halftone-red opacity-25"></div>
        <!-- Radial center glow -->
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(0,192,64,0.07)_0%,transparent_60%)]"></div>
      </div>

      <!-- Vertical accent lines (left = green, right = red) -->
      <div class="absolute left-0 top-0 bottom-0 w-[3px] bg-gradient-to-b from-transparent via-primary to-transparent opacity-80"></div>
      <div class="absolute right-0 top-0 bottom-0 w-[3px] bg-gradient-to-b from-transparent via-danger to-transparent opacity-80"></div>

      <!-- Bottom fade -->
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-black to-transparent"></div>
    </div>

    <!-- ─── Layer 2: Main content ─── -->
    <div id="hero-content" class="absolute inset-0 flex flex-col items-center justify-center z-10 px-5 sm:px-6">

      <!-- Location tag -->
      <div class="flex items-center gap-2 sm:gap-3 mb-4 sm:mb-6 md:mb-8">
        <div class="w-4 sm:w-6 h-px bg-danger"></div>
        <span class="font-dm font-600 text-[10px] sm:text-xs tracking-[0.3em] sm:tracking-[0.35em] uppercase text-white/50">
          Ushuaia · Tierra del Fuego
        </span>
        <div class="w-4 sm:w-6 h-px bg-primary"></div>
      </div>

      <!-- Logo banner -->
      <div class="relative w-full max-w-xs sm:max-w-xl md:max-w-3xl lg:max-w-4xl">
        <div class="absolute inset-x-4 bottom-0 h-8 bg-primary/15 blur-3xl rounded-full"></div>
        <img
          src="/images/logo.png"
          alt="Lunáticos Indumentaria Deportiva — Ushuaia"
          class="w-full h-auto object-contain drop-shadow-[0_0_50px_rgba(0,192,64,0.35)]"
          width="900"
          height="300"
        />
      </div>

      <!-- Divider -->
      <div class="flex items-center gap-4 w-full max-w-[220px] sm:max-w-xs mt-5 sm:mt-7 md:mt-9">
        <div class="flex-1 h-px bg-gradient-to-r from-transparent to-danger/60"></div>
        <span class="w-1.5 h-1.5 sm:w-2 sm:h-2 rounded-full bg-white/30"></span>
        <div class="flex-1 h-px bg-gradient-to-l from-transparent to-primary/60"></div>
      </div>

      <!-- Tagline -->
      <p class="text-white/65 font-dm text-sm sm:text-base md:text-xl max-w-xs sm:max-w-md lg:max-w-lg leading-relaxed text-center mt-4 sm:mt-6 md:mt-7">
        El mejor equipamiento deportivo
        <strong class="text-white/90"> en el fin del mundo.</strong>
        Camisetas oficiales, buzos y artículos de regalería.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-2.5 sm:gap-4 mt-5 sm:mt-7 md:mt-9 w-full max-w-xs sm:max-w-none sm:w-auto">
        <a
          href="#productos"
          class="btn-glow text-center bg-primary text-black font-dm font-700 tracking-wider uppercase text-sm px-8 py-3.5 rounded-full hover:bg-primary-light transition-colors duration-200"
        >
          Ver productos
        </a>
        <a
          href={WA}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center gap-2 border border-white/15 text-white font-dm font-600 tracking-wider uppercase text-sm px-8 py-3.5 rounded-full hover:border-primary/50 hover:text-primary transition-all duration-200"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Consultar stock
        </a>
      </div>
    </div>

    <!-- ─── Layer 3: Bottom chips ─── -->
    <div id="hero-footer" class="absolute bottom-10 left-1/2 -translate-x-1/2 z-10 flex flex-wrap justify-center gap-2 w-full px-4">
      <span class="flex items-center gap-1.5 bg-white/[0.05] border border-white/[0.08] px-3.5 py-1.5 rounded-full text-white/45 font-dm text-xs whitespace-nowrap">
        <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse"></span>
        Lun–Sáb 10:00 – 13:00
      </span>
      <span class="flex items-center gap-1.5 bg-white/[0.05] border border-white/[0.08] px-3.5 py-1.5 rounded-full text-white/45 font-dm text-xs whitespace-nowrap">
        <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse"></span>
        Lun–Sáb 15:30 – 20:00
      </span>
      <span class="flex items-center gap-1.5 bg-white/[0.05] border border-white/[0.08] px-3.5 py-1.5 rounded-full text-white/45 font-dm text-xs whitespace-nowrap">
        📍 Rubinos del Río, Ushuaia
      </span>
    </div>

    <!-- ─── Layer 4: Cinematic image reveal (Maradona) ─── -->
    <!-- Fades in as hero content fades out — GTA VI style chapter reveal -->
    <div id="hero-reveal" class="absolute inset-0 z-20" aria-hidden="true">
      <img
        src="/images/maradona.jpg"
        alt=""
        class="w-full h-full object-cover object-center"
        draggable="false"
      />
      <!-- gradient so it blends into black at exit -->
      <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-black/30"></div>
      <!-- brand accent lines -->
      <div class="absolute left-0 top-0 bottom-0 w-[3px] bg-gradient-to-b from-transparent via-primary to-transparent opacity-60"></div>
      <div class="absolute right-0 top-0 bottom-0 w-[3px] bg-gradient-to-b from-transparent via-danger to-transparent opacity-60"></div>
      <!-- halftone corners -->
      <div class="absolute top-0 left-0 w-48 h-48 halftone-red opacity-40 pointer-events-none"></div>
      <div class="absolute top-0 right-0 w-48 h-48 halftone-green opacity-40 pointer-events-none"></div>
    </div>

    <!-- ─── Scroll indicator ─── -->
    <div id="hero-scroll-hint" class="absolute bottom-10 left-1/2 -translate-x-1/2 z-30 flex flex-col items-center gap-1.5 pointer-events-none">
      <span class="font-dm text-[10px] tracking-[0.25em] uppercase text-white/25">Scroll</span>
      <div class="scroll-arrow w-5 h-5 flex items-center justify-center">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M6 1v10M1 6l5 5 5-5" stroke="rgba(255,255,255,0.3)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    </div>

  </div><!-- /hero-sticky -->
</div><!-- /hero-wrapper -->

<script>
  import gsap from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'

  gsap.registerPlugin(ScrollTrigger)

  // ─── Initial states ───
  gsap.set('#hero-scene',  { scale: 1.12, transformOrigin: 'center center' })
  gsap.set('#hero-reveal', { opacity: 0, scale: 1.08 })

  // ─── Main scroll timeline ───
  const tl = gsap.timeline({
    scrollTrigger: {
      trigger: '#hero-wrapper',
      start:   'top top',
      end:     'bottom bottom',
      scrub:   1.2,
    },
  })

  tl
    // ── Hero content fades up (0 → 0.45) ──
    .to('#hero-content', {
      opacity:  0,
      y:        -40,
      duration: 0.4,
      ease:     'power2.in',
    })

    .to('#hero-footer', {
      opacity:  0,
      duration: 0.3,
      ease:     'power2.in',
    }, '<0.05')

    .to('#hero-scroll-hint', {
      opacity:  0,
      duration: 0.2,
    }, '<')

    // ── Background zoom-out runs through the whole timeline ──
    .to('#hero-scene', {
      scale:    1,
      duration: 1,
      ease:     'none',
    }, 0)

    // ── Maradona fades IN fast (0.15 → 0.35) ──
    .to('#hero-reveal', {
      opacity:  1,
      scale:    1,
      duration: 0.2,
      ease:     'power2.out',
    }, 0.15)

    // ── HOLD at full opacity: 0.35 → 0.78 (GSAP holds last value) ──

    // ── Maradona fades OUT (0.78 → 0.95) ──
    .to('#hero-reveal', {
      opacity:  0,
      scale:    0.97,
      duration: 0.17,
      ease:     'power2.in',
    }, 0.78)

    .to('#hero-scene', {
      opacity:  0,
      duration: 0.05,
    }, 0.95)
</script>

<style>
  /* ─── Halftone dot patterns ─── */
  .halftone-red {
    background-image: radial-gradient(circle, #CC0000 1.5px, transparent 1.5px);
    background-size: 12px 12px;
    mask-image: radial-gradient(ellipse at center, black 0%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 0%, transparent 75%);
  }
  .halftone-green {
    background-image: radial-gradient(circle, #00C040 1.5px, transparent 1.5px);
    background-size: 12px 12px;
    mask-image: radial-gradient(ellipse at center, black 0%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 0%, transparent 75%);
  }

  /* ─── Scroll arrow bounce ─── */
  .scroll-arrow {
    animation: bounce-pulse 2s ease-in-out infinite;
  }
  @keyframes bounce-pulse {
    0%   { transform: translateY(0);   opacity: 0.5; }
    50%  { transform: translateY(5px); opacity: 1;   }
    100% { transform: translateY(0);   opacity: 0.5; }
  }

  /* ─── CTA glow ─── */
  .btn-glow:hover {
    box-shadow: 0 0 22px rgba(0, 192, 64, 0.45), 0 0 44px rgba(0, 192, 64, 0.15);
  }
</style>
