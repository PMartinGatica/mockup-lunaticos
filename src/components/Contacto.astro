---
const WA = 'https://api.whatsapp.com/send?phone=5492901505599&text=Hola%20Lun%C3%A1ticos!%20Quisiera%20consultar%20por...'
const WA2 = 'https://api.whatsapp.com/send?phone=5492901444468&text=Hola%20Lun%C3%A1ticos!%20Quisiera%20consultar%20por...'
const IG = 'https://www.instagram.com/lunaticosindumentaria/'
---

<section id="contacto" class="relative w-full py-16 md:py-24 overflow-hidden">
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-primary/25 to-transparent"></div>
  <div class="absolute inset-0 contacto-glow pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
    <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-start">

      <!-- Left -->
      <div class="flex flex-col gap-6">
        <span class="tag">Donde encontrarnos</span>
        <h2 class="section-title text-4xl md:text-5xl lg:text-6xl leading-tight">
          Visitanos o<br /><span class="text-primary">escribinos</span>
        </h2>
        <p class="text-white/55 font-dm text-base leading-relaxed max-w-md">
          Estamos en Ushuaia. Podés pasar por el local o consultarnos por WhatsApp.
          Te respondemos rápido!
        </p>

        <!-- Contact cards -->
        <div class="flex flex-col gap-3 mt-1">
          <!-- WhatsApp 1 -->
          <a href={WA} target="_blank" rel="noopener noreferrer"
            class="btn-glow flex items-center gap-4 bg-surface border border-white/[0.07] hover:border-primary/30 rounded-xl px-5 py-4 transition-all duration-200 group">
            <div class="w-11 h-11 rounded-full bg-primary/10 border border-primary/30 flex items-center justify-center shrink-0 group-hover:bg-primary/20 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="#22C55E"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            </div>
            <div class="flex flex-col gap-0.5">
              <span class="text-white/35 font-dm text-xs tracking-wider uppercase">WhatsApp</span>
              <span class="font-oswald font-600 text-lg text-white tracking-wider group-hover:text-primary transition-colors">2901 50 55 99</span>
            </div>
          </a>

          <!-- WhatsApp 2 -->
          <a href={WA2} target="_blank" rel="noopener noreferrer"
            class="btn-glow flex items-center gap-4 bg-surface border border-white/[0.07] hover:border-primary/30 rounded-xl px-5 py-4 transition-all duration-200 group">
            <div class="w-11 h-11 rounded-full bg-primary/10 border border-primary/30 flex items-center justify-center shrink-0 group-hover:bg-primary/20 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="#22C55E"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            </div>
            <div class="flex flex-col gap-0.5">
              <span class="text-white/35 font-dm text-xs tracking-wider uppercase">WhatsApp alternativo</span>
              <span class="font-oswald font-600 text-lg text-white tracking-wider group-hover:text-primary transition-colors">2901 44 44 68</span>
            </div>
          </a>

          <!-- Instagram -->
          <a href={IG} target="_blank" rel="noopener noreferrer"
            class="flex items-center gap-4 bg-surface border border-white/[0.07] hover:border-primary/20 rounded-xl px-5 py-4 transition-all duration-200 group">
            <div class="w-11 h-11 rounded-full bg-white/5 border border-white/10 flex items-center justify-center shrink-0 group-hover:border-primary/30 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="rgba(255,255,255,0.5)"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            </div>
            <div class="flex flex-col gap-0.5">
              <span class="text-white/35 font-dm text-xs tracking-wider uppercase">Instagram</span>
              <span class="font-oswald font-600 text-lg text-white/80 tracking-wider group-hover:text-primary transition-colors">@lunaticosindumentaria</span>
            </div>
          </a>

          <!-- Dirección -->
          <div class="flex items-center gap-4 bg-surface border border-white/[0.07] rounded-xl px-5 py-4">
            <div class="w-11 h-11 rounded-full bg-white/5 border border-white/10 flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.4)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div class="flex flex-col gap-0.5">
              <span class="text-white/35 font-dm text-xs tracking-wider uppercase">Dirección</span>
              <span class="font-oswald font-600 text-lg text-white/80 tracking-wider">Rubinos del Río, Ushuaia</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: big CTA panel -->
      <div class="flex flex-col gap-5 bg-surface border border-white/[0.06] rounded-2xl p-7 md:p-10">
        <div class="w-14 h-14 rounded-full bg-primary/10 border-2 border-primary/30 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="#22C55E"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        </div>
        <h3 class="font-oswald font-700 text-3xl md:text-4xl text-white uppercase tracking-wide leading-tight">
          ¿Buscás una camiseta<br /><span class="text-primary">en especial?</span>
        </h3>
        <p class="text-white/50 font-dm text-sm leading-relaxed">
          Consultanos por WhatsApp y te decimos si tenemos stock o lo podemos conseguir.
          Respondemos en el horario de atención.
        </p>
        <a
          href={WA}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-glow w-full text-center bg-primary text-[#0A0A0A] font-dm font-700 tracking-wider uppercase text-sm py-4 rounded-xl hover:bg-[#4ade80] transition-colors duration-200 mt-2"
        >
          Consultar por WhatsApp →
        </a>
        <p class="text-white/25 font-dm text-xs text-center">
          Respondemos en horario de atención · Lun–Sáb 10–13 y 15:30–20
        </p>
      </div>

    </div>
  </div>
</section>

<style>
  .contacto-glow {
    background: radial-gradient(ellipse at 50% 100%, rgba(34, 197, 94, 0.05) 0%, transparent 60%);
  }
</style>
