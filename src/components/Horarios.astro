---
const WA = 'https://api.whatsapp.com/send?phone=5492901505599&text=Hola%20Lun%C3%A1ticos!%20Quisiera%20consultar%20por...'

const horario = [
  { dia: 'Lunes', manana: '10:00 – 13:00', tarde: '15:30 – 20:00', activo: true },
  { dia: 'Martes', manana: '10:00 – 13:00', tarde: '15:30 – 20:00', activo: true },
  { dia: 'Miércoles', manana: '10:00 – 13:00', tarde: '15:30 – 20:00', activo: true },
  { dia: 'Jueves', manana: '10:00 – 13:00', tarde: '15:30 – 20:00', activo: true },
  { dia: 'Viernes', manana: '10:00 – 13:00', tarde: '15:30 – 20:00', activo: true },
  { dia: 'Sábado', manana: '10:00 – 13:00', tarde: '15:30 – 20:00', activo: true },
  { dia: 'Domingo', manana: null, tarde: null, activo: false },
]
---

<section id="horarios" class="relative w-full py-16 md:py-24 overflow-hidden">
  <!-- Background accent -->
  <div class="absolute inset-0 horarios-bg pointer-events-none"></div>
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-primary/30 to-transparent"></div>
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-primary/20 to-transparent"></div>

  <div class="relative max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
    <div class="grid md:grid-cols-2 gap-12 md:gap-20 items-start">

      <!-- Left: big clock display -->
      <div class="flex flex-col gap-6">
        <span class="tag">Cuándo encontrarnos</span>
        <h2 class="section-title text-4xl md:text-5xl lg:text-6xl">
          Horarios de<br /><span class="text-primary">Atención</span>
        </h2>
        <p class="text-white/55 font-dm text-base leading-relaxed max-w-md">
          Te esperamos en nuestra tienda en Ushuaia. <strong class="text-white/80">Lunes a Sábados</strong>,
          en dos turnos para que siempre puedas pasar.
        </p>

        <!-- Big visual times -->
        <div class="flex flex-col gap-4 mt-2">
          <div class="flex items-center gap-5 p-5 rounded-xl bg-surface border border-white/[0.06]">
            <div class="w-12 h-12 rounded-full bg-primary/10 border border-primary/30 flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#22C55E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div>
              <p class="text-white/40 font-dm text-xs tracking-widest uppercase mb-0.5">Turno mañana</p>
              <p class="font-oswald font-700 text-2xl text-white tracking-wider">10:00 – 13:00 hs</p>
            </div>
          </div>
          <div class="flex items-center gap-5 p-5 rounded-xl bg-surface border border-white/[0.06]">
            <div class="w-12 h-12 rounded-full bg-primary/10 border border-primary/30 flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#22C55E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div>
              <p class="text-white/40 font-dm text-xs tracking-widest uppercase mb-0.5">Turno tarde</p>
              <p class="font-oswald font-700 text-2xl text-white tracking-wider">15:30 – 20:00 hs</p>
            </div>
          </div>
        </div>

        <a
          href={WA}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-glow w-fit flex items-center gap-2 bg-primary text-[#0A0A0A] font-dm font-700 text-sm tracking-wider uppercase px-6 py-3 rounded-full hover:bg-[#4ade80] transition-colors duration-200 mt-2"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Consultar disponibilidad
        </a>
      </div>

      <!-- Right: weekly grid -->
      <div class="flex flex-col gap-2">
        {horario.map((d) => (
          <div
            class={`flex items-center justify-between gap-2 px-4 py-3 sm:px-5 sm:py-4 rounded-xl border transition-all duration-200 ${
              d.activo
                ? 'bg-surface border-white/[0.06] hover:border-primary/25'
                : 'bg-[#0A0A0A] border-white/[0.03] opacity-40'
            }`}
          >
            <span class={`font-oswald font-600 text-base sm:text-lg uppercase tracking-wide shrink-0 ${d.activo ? 'text-white' : 'text-white/30'}`}>
              {d.dia}
            </span>
            {d.activo ? (
              <div class="flex flex-col sm:flex-row items-end sm:items-center gap-0.5 sm:gap-3 text-right">
                <span class="text-primary/70 font-dm text-xs sm:text-sm">{d.manana}</span>
                <span class="hidden sm:inline text-white/20 font-dm text-xs">·</span>
                <span class="text-primary/70 font-dm text-xs sm:text-sm">{d.tarde}</span>
              </div>
            ) : (
              <span class="text-white/25 font-dm text-sm">Cerrado</span>
            )}
          </div>
        ))}
      </div>

    </div>
  </div>
</section>

<style>
  .horarios-bg {
    background:
      radial-gradient(ellipse at 0% 50%, rgba(34, 197, 94, 0.04) 0%, transparent 50%),
      radial-gradient(ellipse at 100% 50%, rgba(34, 197, 94, 0.02) 0%, transparent 50%);
  }
</style>
