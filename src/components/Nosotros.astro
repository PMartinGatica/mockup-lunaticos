---
---

<section id="nosotros" class="relative w-full py-16 md:py-24">
  <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
    <div class="grid md:grid-cols-2 gap-12 md:gap-20 items-center">

      <!-- Left: product collage -->
      <div class="relative grid grid-cols-2 gap-3 md:gap-4">
        <div class="col-span-2 aspect-[16/9] rounded-xl overflow-hidden bg-surface">
          <img src="/images/prod-arg-titular.jpg" alt="Camiseta Argentina" class="w-full h-full object-contain bg-[#1A1A1A]" loading="lazy" />
        </div>
        <div class="aspect-square rounded-xl overflow-hidden bg-surface">
          <img src="/images/prod-river.jpg" alt="River Plate" class="w-full h-full object-contain bg-[#1A1A1A]" loading="lazy" />
        </div>
        <div class="aspect-square rounded-xl overflow-hidden bg-surface">
          <img src="/images/prod-boca.jpg" alt="Boca Juniors" class="w-full h-full object-contain bg-[#1A1A1A]" loading="lazy" />
        </div>
        <!-- Floating badge -->
        <div class="absolute -bottom-3 -right-3 sm:-bottom-4 sm:-right-4 bg-primary text-[#0A0A0A] font-oswald font-700 text-xs sm:text-sm uppercase tracking-wider px-3 sm:px-4 py-1.5 sm:py-2 rounded-xl shadow-lg shadow-primary/20">
          Ushuaia, TdF
        </div>
      </div>

      <!-- Right: text -->
      <div class="flex flex-col gap-6">
        <span class="tag">Quiénes somos</span>
        <h2 class="section-title text-4xl md:text-5xl lg:text-6xl leading-tight">
          Pasión por el<br /><span class="text-primary">deporte</span><br />en el fin del mundo
        </h2>
        <p class="text-white/60 font-dm text-base leading-relaxed">
          <strong class="text-white/85">Lunáticos Indumentaria Deportiva</strong> es una tienda de Ushuaia
          especializada en camisetas y artículos de regalería deportiva.
          Encontrás las camisetas más pedidas de la Selección Argentina, los grandes clubes nacionales y mucho más.
        </p>
        <p class="text-white/50 font-dm text-sm leading-relaxed">
          Estamos ubicados en Rubinos del Río, Ushuaia. Atendemos de lunes a sábado en dos turnos
          para que siempre puedas pasar a elegir tu equipamiento.
        </p>

        <!-- Tags de productos -->
        <div class="flex flex-wrap gap-2 mt-1">
          {['Selección Argentina', 'River Plate', 'Boca Juniors', 'Adidas', 'Regalería', 'Deportiva'].map((t) => (
            <span class="bg-surface border border-primary/20 text-primary/70 font-dm text-xs tracking-wider uppercase px-3 py-1.5 rounded-full">
              {t}
            </span>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>
